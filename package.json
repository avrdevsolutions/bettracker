{
  "name": "bettracker",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:server": "pnpm --filter @bettracker/server dev",
    "dev:client": "pnpm --filter @bettracker/client dev",
    "build": "pnpm --filter @bettracker/server build && pnpm --filter @bettracker/client build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "migrate:up": "pnpm --filter @bettracker/server migrate:up",
    "migrate:down": "pnpm --filter @bettracker/server migrate:down",
    "clean": "pnpm -r run clean"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.0.0"
  }
}
